      <aliases enabled='yes' />
      <column caption='Profit Margin' datatype='real' name='[Calculation_0195730194624512]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit]) / SUM([sales])' />
      </column>
      <column caption='Cost' datatype='real' name='[Calculation_0195730194870273]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales]) - SUM([profit])' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_0195730194964482]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales]) / COUNT([order_id])' />
      </column>
      <column caption='Return Rate' datatype='real' name='[Calculation_0195730196779012]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([return_flag])/COUNT([order_id])' />
      </column>
      <column caption='Shipping Delay Bucket' datatype='string' name='[Calculation_0195730197782533]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [delivery_days] &lt;= 2 THEN &quot;0–2 Days&quot;&#10;ELSEIF [delivery_days] &lt;= 5 THEN &quot;3–5 Days&quot;&#10;ELSEIF [delivery_days] &lt;= 7 THEN &quot;6–7 Days&quot;&#10;ELSE &quot;More than 7 Days&quot;&#10;END' />
      </column>
